        </mj-column>
      </mj-section>

      <mj-section mj-class="pb-16">
        <mj-column>
          <mj-divider />

          <mj-text mj-class="heading-3 c-blue pb-8">
            It don't come easy
          </mj-text>
          <mj-text mj-class="pb-8">
            You know it don't come easy. It don't come easy. You know it don't come easy…
          </mj-text>
          <mj-text mj-class="meta-text pb-16">
